<?xml version = "1.0" encoding = "UTF-8" ?>
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="BloomBeauty.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackgroundColor">#FFFFFF</Color>
            <Color x:Key="PrimaryColor">#C83131</Color>
            <Color x:Key="SecondaryColor">#F5F5F5</Color>
            <Color x:Key="TextColor">#333333</Color>
            <Color x:Key="MutedTextColor">#999999</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
