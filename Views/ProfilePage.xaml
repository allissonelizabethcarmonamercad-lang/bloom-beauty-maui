<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BloomBeauty.ProfilePage"
             Title="Perfil">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">
            <Label Text="Mi Perfil" FontSize="24" FontAttributes="Bold" TextColor="#C83131"/>

            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="👤" FontSize="60" HorizontalOptions="Center"/>
                <Label Text="Usuario" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                <Label Text="usuario@email.com" FontSize="12" TextColor="#999999" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Mi Información" FontSize="14" FontAttributes="Bold" TextColor="#C83131"/>
                
                <Frame BorderColor="#CCCCCC" CornerRadius="8" Padding="15" HasShadow="False">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Nombre" FontSize="11" TextColor="#999999" FontAttributes="Bold"/>
                            <Label Text="Tu Nombre" FontSize="13"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Email" FontSize="11" TextColor="#999999" FontAttributes="Bold"/>
                            <Label Text="correo@example.com" FontSize="13"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Teléfono" FontSize="11" TextColor="#999999" FontAttributes="Bold"/>
                            <Label Text="+52 123 456 7890" FontSize="13"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Mis Compras" FontSize="14" FontAttributes="Bold" TextColor="#C83131"/>
                <Label Text="No hay compras registradas" FontSize="12" TextColor="#999999" HorizontalTextAlignment="Center" Padding="20"/>
            </VerticalStackLayout>

            <Button Text="Editar Perfil" BackgroundColor="#C83131" TextColor="White" CornerRadius="8"/>
            <Button Text="Cerrar Sesión" BackgroundColor="Transparent" TextColor="#C83131" BorderColor="#C83131" BorderWidth="2" CornerRadius="8"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
