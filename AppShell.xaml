<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BloomBeauty.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <TabBar>
        <ShellContent 
            Title="Inicio" 
            Icon="home.png"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        
        <ShellContent 
            Title="Favoritos" 
            Icon="heart.png"
            ContentTemplate="{DataTemplate local:FavoritesPage}"
            Route="FavoritesPage" />
        
        <ShellContent 
            Title="Carrito" 
            Icon="bag.png"
            ContentTemplate="{DataTemplate local:CartPage}"
            Route="CartPage" />
        
        <ShellContent 
            Title="Perfil" 
            Icon="person.png"
            ContentTemplate="{DataTemplate local:ProfilePage}"
            Route="ProfilePage" />
    </TabBar>

</Shell>
